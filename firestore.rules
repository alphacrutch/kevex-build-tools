rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function creatingOwnedDoc() {
      return signedIn() && request.resource.data.userId == request.auth.uid;
    }

    function existingOwnedDoc() {
      return signedIn() && resource.data.userId == request.auth.uid;
    }

    match /users/{userId} {
      allow create, read: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false;
    }

    match /quotes/{quoteId} {
      allow create: if creatingOwnedDoc();
      allow read, delete: if existingOwnedDoc();
      allow update: if existingOwnedDoc() && request.resource.data.userId == resource.data.userId;
    }

    match /quoteTemplates/{templateId} {
      allow create: if creatingOwnedDoc();
      allow read, delete: if existingOwnedDoc();
      allow update: if existingOwnedDoc() && request.resource.data.userId == resource.data.userId;
    }

    match /clients/{clientId} {
      allow create: if creatingOwnedDoc();
      allow read, delete: if existingOwnedDoc();
      allow update: if existingOwnedDoc() && request.resource.data.userId == resource.data.userId;
    }

    match /jobs/{jobId} {
      allow create: if creatingOwnedDoc();
      allow read, delete: if existingOwnedDoc();
      allow update: if existingOwnedDoc() && request.resource.data.userId == resource.data.userId;
    }

    match /invoices/{invoiceId} {
      allow create: if creatingOwnedDoc();
      allow read, delete: if existingOwnedDoc();
      allow update: if existingOwnedDoc() && request.resource.data.userId == resource.data.userId;
    }

    match /creditPurchases/{purchaseId} {
      allow create: if creatingOwnedDoc();
      allow read: if existingOwnedDoc();
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
