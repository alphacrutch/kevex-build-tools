rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /serviceRequests/{requestId} {
      allow create: if request.resource.data.keys().hasOnly([
        'categoryKey',
        'serviceId',
        'serviceTitle',
        'name',
        'email',
        'phone',
        'notes',
        'details',
        'metadata',
        'createdAt'
      ])
      && request.resource.data.categoryKey is string
      && request.resource.data.categoryKey.size() > 0
      && request.resource.data.serviceId is string
      && request.resource.data.serviceId.size() > 0
      && request.resource.data.serviceTitle is string
      && request.resource.data.serviceTitle.size() > 0
      && request.resource.data.name is string
      && request.resource.data.name.size() > 1
      && request.resource.data.email is string
      && request.resource.data.email.size() > 3
      && request.resource.data.phone is string
      && request.resource.data.phone.size() > 5
      && request.resource.data.notes is string
      && request.resource.data.details is map
      && request.resource.data.metadata is map
      && request.resource.data.createdAt is timestamp;

      allow read, update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
